rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isVerified() {
      return isSignedIn();
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'project.speedup@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /admins/{userId} {
      allow get: if isVerified() && isValidId(userId);
      allow list: if isVerified();
      allow create, update, delete: if isAdmin() && isValidId(userId);
    }

    match /settings/{docId} {
      allow get: if isVerified();
      allow list: if isVerified();
      allow create, update, delete: if isAdmin();
    }

    match /admin_data/{docId} {
      allow get: if isVerified();
      allow list: if isVerified();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/settings/{docId} {
      allow read, write: if isVerified() && request.auth.uid == userId;
    }

    match /calculations/{calcId} {
      function isValidCalculation(data) {
        return data.userId == request.auth.uid &&
               data.createdAt == request.time;
      }
      
      allow get: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidCalculation(incoming());
      
      allow update: if isVerified() && 
        incoming().userId == request.auth.uid && 
        existing().userId == request.auth.uid &&
        incoming().createdAt == existing().createdAt;
        
      allow delete: if isVerified() && (isAdmin() || existing().userId == request.auth.uid);
      
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
    }
  }
}
